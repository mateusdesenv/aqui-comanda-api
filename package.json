{
  "name": "aqui-comanda-api",
  "version": "1.0.0",
  "description": "Aqui Comanda API - REST API Node.js, TypeScript, MongoDB and Firebase Admin.",
  "main": "dist/server.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/database/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "aqui-comanda",
    "api",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.2.0",
    "mongoose": "^9.7.3",
    "morgan": "^1.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
