{
  "version": 2,
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/favicon.ico",
      "destination": "/api/favicon"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/health.js": {
      "maxDuration": 10
    },
    "api/favicon.js": {
      "maxDuration": 10
    }
  }
}
